# FreshGuard Backend 환경변수 예시
# 이 파일을 복사해서 .env 로 저장하고 실제 값을 입력하세요.
# .env 파일은 절대 GitHub에 커밋하지 마세요.

# Railway PostgreSQL 연결 URL
DATABASE_URL=postgresql://user:password@localhost:5432/freshguard

# JWT 서명용 비밀키 (openssl rand -hex 32 로 생성 권장)
JWT_SECRET=your-very-long-random-secret-key-here

JWT_ALGORITHM=HS256

# 토큰 만료 시간 (분 단위), 10080 = 7일
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 허용 오리진 (쉼표 구분)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://freshguard.vercel.app
