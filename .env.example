# FreshGuard 환경변수 예시
# 이 파일을 복사해서 .env.local 로 저장하고 실제 값을 입력하세요.
# .env.local 은 절대 커밋하지 마세요.

# ─── 백엔드 모드 ───────────────────────────────────────────────────────────────
# local   : localStorage + mock auth 사용 (기본값, 서버 없이 동작)
# supabase: Supabase auth + Supabase database 사용 (optional)
# api     : Railway FastAPI 백엔드 사용 (운영 기본 모드)
VITE_BACKEND_MODE=local

# ─── API 모드 설정 (VITE_BACKEND_MODE=api 일 때 필요) ───────────────────────
# Railway 배포 URL 또는 로컬 개발 서버 주소
# 로컬 개발: http://localhost:8000
# Railway 운영: https://freshguard-api.up.railway.app
VITE_API_BASE_URL=http://localhost:8000

# ─── Supabase 설정 (VITE_BACKEND_MODE=supabase 일 때 필요) ──────────────────
# Supabase 프로젝트 대시보드 → Settings → API 에서 확인
# 현재 FreshGuard의 기본 운영 방향은 api 모드입니다. Supabase는 대안/참고용으로 보존됩니다.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
